{
  "expo": {
    "name": "Immpression",
    "slug": "Immpression",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "com.immpression.Immpression",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.immpression.Immpression",
      "config": {
        "googleSignIn": {
          "reservedClientId": "com.googleusercontent.apps.31361740434-uasqvn754uln5hgcijp6n59lc4ig4s74"
        }
      },
      "usesNonExemptEncryption": false,
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.31361740434-uasqvn754uln5hgcijp6n59lc4ig4s74"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.immpression.Immpression",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.immpression.Immpression",
              "host": "oauth2redirect"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f013e252-c529-4ba4-afbe-9f233d8f28fc"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f013e252-c529-4ba4-afbe-9f233d8f28fc"
    },
    "owner": "immpression",
    "plugins": [
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ]
  }
}